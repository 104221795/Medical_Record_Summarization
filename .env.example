# Step 1 RAG backend defaults: local retrieval plus extractive output.
RAG_ENVIRONMENT=development
RAG_EMBEDDING_PROVIDER=hashing
RAG_GENERATOR_PROVIDER=extractive
# Persistence foundation. Use a secret-managed PostgreSQL URL outside local development:
# RAG_DATABASE_URL=postgresql+psycopg://app_user:replace-with-secret@db.internal:5432/clin_summ
RAG_DATABASE_URL=sqlite:///./var/clin_summ.db
RAG_DATABASE_ECHO=false
# Local development defaults to in-memory Qdrant to support --reload safely.
# To persist single-process local data only:
# RAG_QDRANT_PATH=backend/var/qdrant
# Production / multiple workers:
# RAG_QDRANT_URL=http://qdrant.internal:6333

# Private/local ONNX embedding deployment:
# RAG_EMBEDDING_PROVIDER=fastembed
# RAG_FASTEMBED_MODEL=intfloat/multilingual-e5-large
# RAG_ORT_EXECUTION_PROVIDER=CPUExecutionProvider
# Intel image: RAG_ORT_EXECUTION_PROVIDER=OpenVINOExecutionProvider
# NVIDIA image: RAG_ORT_EXECUTION_PROVIDER=CUDAExecutionProvider
# RAG_ORT_INTRA_OP_THREADS=2


# Legacy RAG/demo Gemini generator. Approved de-identified demonstration only:
# RAG_GENERATOR_PROVIDER=gemini
# RAG_GEMINI_API_KEY=your-google-ai-studio-api-key

# Persisted summary workflow Gemini provider.
# Disabled by default. Enable only for de-identified or formally governed data:
# RAG_LLM_PROVIDER=gemini
# RAG_LLM_EXTERNAL_ENABLED=true
# RAG_LLM_ALLOW_PHI_EXTERNAL=true
# RAG_GEMINI_API_KEY=your-google-ai-studio-api-key
# RAG_GEMINI_MODEL=gemini-2.5-flash-lite

# Multi-modal preprocessing: local Whisper speech-to-text and ViT features.
RAG_WHISPER_MODEL=openai/whisper-small
RAG_WHISPER_DEVICE=-1
RAG_VIT_MODEL=google/vit-base-patch16-224-in21k
RAG_VISION_DEVICE=cpu
RAG_MAXIMUM_AUDIO_BYTES=52428800
RAG_MAXIMUM_IMAGE_BYTES=20971520

# FHIR R4 mapper mock destination; no external write is performed by mock endpoint.
RAG_FHIR_MOCK_BASE_URL=https://hapi.fhir.local/fhir/R4
RAG_FHIR_MAPPER_DEVICE_REFERENCE=Device/clinical-summarization-service

# MLflow telemetry: metrics only; no raw PHI/clinical text is logged by default.
RAG_MLFLOW_ENABLED=false
RAG_MLFLOW_TRACKING_URI=sqlite:///./backend/var/mlflow.db
RAG_MLFLOW_EXPERIMENT_NAME=medical-record-summarization
RAG_MLFLOW_LOG_REDACTED_SAFETY_ARTIFACTS=true

# Local ONNX NLI validator for EMR/FHIR writeback safety.
# Model folder must contain model.onnx plus Hugging Face tokenizer/config files.
# RAG_MEDICAL_NLI_MODEL_PATH=./backend/models/deberta-v3-nli-small-onnx
# RAG_MEDICAL_NLI_CONTRADICTION_THRESHOLD=0.80
# Set true in controlled production after provisioning the local ONNX model.
RAG_MEDICAL_NLI_REQUIRED_FOR_WRITEBACK=false
