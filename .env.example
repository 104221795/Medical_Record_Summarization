# Medical Record Summarization MVP - safe example config
# Copy to .env for local development only. Never commit real secrets.

# App/runtime
RAG_APP_NAME=Medical Record Summarization RAG API
RAG_ENVIRONMENT=development
RAG_API_PREFIX=/api/v1
PORT=8080
HOST=127.0.0.1
RAG_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Auth/session
RAG_AUTH_SECRET_KEY=replace-with-a-long-random-secret
RAG_AUTH_TOKEN_TTL_MINUTES=720
GOOGLE_CLIENT_ID=

# Database
# Local SQLite:
RAG_DATABASE_URL=sqlite:///./var/clin_summ.db
RAG_DATABASE_ECHO=false
# Railway/Postgres:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
# RAG_DATABASE_URL=${DATABASE_URL}

# Retrieval/vector store
RAG_EMBEDDING_PROVIDER=sentence_transformers
RAG_SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_SENTENCE_TRANSFORMERS_LOCAL_FILES_ONLY=false
RAG_QDRANT_URL=
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=clinical_record_chunks

# Hugging Face cache
# Local Windows example:
# HF_HOME=D:\hf_cache
# HF_HUB_CACHE=D:\hf_cache\hub
# HF_DATASETS_CACHE=D:\hf_cache\datasets
# TRANSFORMERS_CACHE=D:\hf_cache\hub
# Container/Railway-friendly example:
HF_HOME=/tmp/hf_cache
HF_HUB_CACHE=/tmp/hf_cache/hub
HF_DATASETS_CACHE=/tmp/hf_cache/datasets
TRANSFORMERS_CACHE=/tmp/hf_cache/hub

# Background jobs
RAG_JOB_BACKEND=in_process
RAG_REDIS_URL=redis://127.0.0.1:6379/0
RAG_RQ_QUEUE_NAME=clin_summ_jobs
RAG_JOB_FALLBACK_TO_IN_PROCESS=true
RAG_RQ_REQUIRE_LIVE_WORKER=false

# Evaluation/admin artifacts
RAG_EVALUATION_ARTIFACT_ROOT=
RAG_INCLUDE_BERTSCORE=false
RAG_BERTSCORE_MODEL_TYPE=roberta-large
RAG_BERTSCORE_DEVICE=cpu

# Local/provider execution
RUN_REAL_BASELINES=0
RAG_RUN_REAL_BASELINES=0
RAG_BART_MODEL_NAME=facebook/bart-large-cnn
RAG_PEGASUS_MODEL_NAME=google/pegasus-pubmed

# Ollama local testing only. Railway usually should not rely on Ollama.
OLLAMA_MODELS=
OLLAMA_API_BASE=http://127.0.0.1:11434
LLM_GATEWAY_MODE=litellm
LLM_GATEWAY_BASE_URL=http://127.0.0.1:4000
LLM_GATEWAY_TIMEOUT_SECONDS=180
LLM_GATEWAY_TEMPERATURE=0.1
LLM_GATEWAY_MAX_TOKENS=384
LLM_GATEWAY_LOCAL_NUM_CTX=8192

# Gemini optional governed provider. Leave blank unless intentionally enabled.
GEMINI_API_KEY=
RAG_GEMINI_API_KEY=
RAG_GEMINI_MODEL=gemini-2.5-flash-lite
RAG_LLM_PROVIDER=deterministic
RAG_LLM_EXTERNAL_ENABLED=false
RAG_LLM_ALLOW_PHI_EXTERNAL=false

# Frontend build/runtime
VITE_API_PREFIX=/api/v1
# Set only when frontend is hosted on a different domain from backend.
VITE_API_BASE_URL=
