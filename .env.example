RAG_APP_NAME=Medical Record Summarization RAG API
RAG_ENVIRONMENT=development
RAG_API_PREFIX=/api/v1
RAG_AUTH_SECRET_KEY=change-me-with-a-secret-manager
RAG_AUTH_TOKEN_TTL_MINUTES=720

# Local SQLite default:
RAG_DATABASE_URL=sqlite:///./var/clin_summ.db
RAG_DATABASE_ECHO=false

# PostgreSQL option. DATABASE_URL and RAG_DATABASE_URL are both supported.
# DATABASE_URL=postgresql+psycopg://clin_summ:clin_summ_dev@127.0.0.1:5433/clin_summ
# RAG_DATABASE_URL=postgresql+psycopg://clin_summ:clin_summ_dev@127.0.0.1:5433/clin_summ

RAG_EMBEDDING_PROVIDER=sentence_transformers
RAG_SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_SENTENCE_TRANSFORMERS_LOCAL_FILES_ONLY=true

HF_HOME=D:\hf_cache
HF_HUB_CACHE=D:\hf_cache\hub
HF_DATASETS_CACHE=D:\hf_cache\datasets
TRANSFORMERS_CACHE=D:\hf_cache\hub

RUN_REAL_BASELINES=0
RAG_RUN_REAL_BASELINES=0
RAG_BART_MODEL_NAME=facebook/bart-large-cnn
RAG_PEGASUS_MODEL_NAME=google/pegasus-pubmed
PEGASUS_PUBMED_MODEL_NAME=google/pegasus-pubmed
PEGASUS_CNN_DAILYMAIL_MODEL_NAME=google/pegasus-cnn_dailymail
PEGASUS_XSUM_MODEL_NAME=google/pegasus-xsum

# Gemini stays disabled unless governance/API configuration is explicit.
# GEMINI_API_KEY=
# GOOGLE_CLIENT_ID=
# RAG_LLM_PROVIDER=gemini
# RAG_LLM_EXTERNAL_ENABLED=true
# RAG_LLM_ALLOW_PHI_EXTERNAL=false
